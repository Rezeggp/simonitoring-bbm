APP_NAME="SIMONITORING BBM"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=Asia/Jakarta
APP_LOCALE=id

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ============================================================
# KONFIGURASI DATABASE
# Opsi 1 (PALING MUDAH — tidak perlu install MySQL/MariaDB):
# Gunakan SQLite. Cukup buat file kosong database/database.sqlite
# lalu biarkan baris di bawah ini aktif.
# ============================================================
DB_CONNECTION=sqlite

# ============================================================
# Opsi 2 — Jika ingin menggunakan MySQL/MariaDB:
# Hapus tanda komentar (#) pada 5 baris di bawah, lalu komentari
# baris "DB_CONNECTION=sqlite" di atas.
# ============================================================
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=simonitoring_bbm
# DB_USERNAME=root
# DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@simonitoring-bbm.test"
MAIL_FROM_NAME="${APP_NAME}"
